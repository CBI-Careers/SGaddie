<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Shavon Gaddie — Revenue Cycle Leader</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Montserrat:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<style>
  :root {
    --rose-gold: #C9A87C;
    --rose-mid: #D9BC98;
    --rose-dark: #A07848;
    --rose-pale: #F0E6D8;
    --dark: #0D0F12;
    --dark-mid: #1A1D22;
    --dark-card: #22262D;
    --dark-sidebar: #2A2E35;
    --white: #FFFFFF;
    --off-white: #F8F4F0;
    --ink: #1A1A1A;
    --mid: #888888;
    --light: #BBAFA8;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  html { scroll-behavior: smooth; }

  body {
    background: var(--dark);
    color: var(--off-white);
    font-family: 'Montserrat', sans-serif;
    font-weight: 300;
    overflow-x: hidden;
  }

  /* ── NOISE TEXTURE OVERLAY ─────────────────────────────────────── */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.03'/%3E%3C/svg%3E");
    pointer-events: none;
    z-index: 1000;
    opacity: 0.4;
  }

  /* ── HERO ──────────────────────────────────────────────────────── */
  .hero {
    min-height: 100vh;
    position: relative;
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 80% 60% at 70% 40%, rgba(201,168,124,0.08) 0%, transparent 60%),
      radial-gradient(ellipse 50% 80% at 10% 80%, rgba(160,120,72,0.06) 0%, transparent 50%),
      linear-gradient(135deg, #0D0F12 0%, #161920 50%, #0D0F12 100%);
  }

  .hero-line {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: linear-gradient(90deg, transparent, var(--rose-gold), transparent);
    animation: shimmer 3s ease-in-out infinite;
  }

  @keyframes shimmer {
    0%, 100% { opacity: 0.4; }
    50% { opacity: 1; }
  }

  .hero-content {
    position: relative;
    z-index: 2;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 60px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: center;
  }

  .hero-left { animation: fadeSlideUp 1s ease forwards; opacity: 0; }
  .hero-right { animation: fadeSlideUp 1s ease 0.3s forwards; opacity: 0; }

  @keyframes fadeSlideUp {
    from { opacity: 0; transform: translateY(30px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .eyebrow {
    font-family: 'Montserrat', sans-serif;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 4px;
    color: var(--rose-gold);
    text-transform: uppercase;
    margin-bottom: 24px;
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .eyebrow::before {
    content: '';
    width: 32px;
    height: 1px;
    background: var(--rose-gold);
  }

  .hero-name {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(52px, 6vw, 80px);
    font-weight: 300;
    line-height: 1.05;
    color: var(--white);
    margin-bottom: 8px;
  }

  .hero-name span {
    color: var(--rose-gold);
    font-style: italic;
  }

  .hero-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: 18px;
    font-weight: 400;
    color: var(--rose-mid);
    margin-bottom: 32px;
    letter-spacing: 1px;
  }

  .hero-tagline {
    font-size: 13px;
    font-weight: 300;
    color: var(--light);
    line-height: 1.8;
    max-width: 420px;
    margin-bottom: 48px;
    border-left: 2px solid var(--rose-gold);
    padding-left: 20px;
  }

  .hero-cta {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 14px 32px;
    background: var(--rose-gold);
    color: var(--dark);
    font-family: 'Montserrat', sans-serif;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 2px;
    text-transform: uppercase;
    text-decoration: none;
    transition: all 0.3s ease;
  }

  .btn-primary:hover {
    background: var(--rose-mid);
    transform: translateY(-2px);
  }

  .btn-secondary {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 14px 32px;
    border: 1px solid rgba(201,168,124,0.4);
    color: var(--rose-gold);
    font-family: 'Montserrat', sans-serif;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 2px;
    text-transform: uppercase;
    text-decoration: none;
    transition: all 0.3s ease;
  }

  .btn-secondary:hover {
    border-color: var(--rose-gold);
    background: rgba(201,168,124,0.08);
    transform: translateY(-2px);
  }

  /* Metrics cards */
  .metrics-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }

  .metric-card {
    background: var(--dark-card);
    border: 1px solid rgba(201,168,124,0.12);
    padding: 28px 24px;
    position: relative;
    overflow: hidden;
    transition: all 0.3s ease;
    animation: fadeSlideUp 1s ease forwards;
    opacity: 0;
  }

  .metric-card:nth-child(1) { animation-delay: 0.5s; }
  .metric-card:nth-child(2) { animation-delay: 0.65s; }
  .metric-card:nth-child(3) { animation-delay: 0.8s; }
  .metric-card:nth-child(4) { animation-delay: 0.95s; }

  .metric-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: var(--rose-gold);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.4s ease;
  }

  .metric-card:hover { border-color: rgba(201,168,124,0.3); transform: translateY(-4px); }
  .metric-card:hover::before { transform: scaleX(1); }

  .metric-number {
    font-family: 'Cormorant Garamond', serif;
    font-size: 48px;
    font-weight: 300;
    color: var(--rose-gold);
    line-height: 1;
    margin-bottom: 6px;
  }

  .metric-label {
    font-size: 9px;
    font-weight: 600;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--light);
  }

  /* ── NAV ───────────────────────────────────────────────────────── */
  nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    padding: 24px 60px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    background: linear-gradient(180deg, rgba(13,15,18,0.95) 0%, transparent 100%);
    backdrop-filter: blur(10px);
  }

  .nav-logo {
    font-family: 'Cormorant Garamond', serif;
    font-size: 22px;
    font-weight: 400;
    color: var(--white);
    text-decoration: none;
    letter-spacing: 1px;
  }

  .nav-logo span { color: var(--rose-gold); font-style: italic; }

  .nav-links {
    display: flex;
    gap: 40px;
    list-style: none;
  }

  .nav-links a {
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--light);
    text-decoration: none;
    transition: color 0.3s ease;
  }

  .nav-links a:hover { color: var(--rose-gold); }

  /* ── SECTIONS ──────────────────────────────────────────────────── */
  section {
    max-width: 1200px;
    margin: 0 auto;
    padding: 100px 60px;
  }

  .section-eyebrow {
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 4px;
    color: var(--rose-gold);
    text-transform: uppercase;
    margin-bottom: 16px;
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .section-eyebrow::before {
    content: '';
    width: 32px;
    height: 1px;
    background: var(--rose-gold);
  }

  .section-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(36px, 4vw, 54px);
    font-weight: 300;
    color: var(--white);
    line-height: 1.1;
    margin-bottom: 60px;
  }

  .section-title em {
    color: var(--rose-gold);
    font-style: italic;
  }

  /* ── ABOUT ─────────────────────────────────────────────────────── */
  .about-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: start;
  }

  .about-text p {
    font-size: 14px;
    font-weight: 300;
    line-height: 1.9;
    color: var(--light);
    margin-bottom: 20px;
  }

  .about-text p strong {
    color: var(--rose-mid);
    font-weight: 500;
  }

  .about-divider {
    width: 48px;
    height: 1px;
    background: var(--rose-gold);
    margin: 32px 0;
  }

  /* Certifications */
  .cert-list {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .cert-item {
    display: flex;
    align-items: flex-start;
    gap: 16px;
    padding: 20px;
    background: var(--dark-card);
    border: 1px solid rgba(201,168,124,0.1);
    transition: all 0.3s ease;
  }

  .cert-item:hover {
    border-color: rgba(201,168,124,0.3);
    transform: translateX(4px);
  }

  .cert-badge {
    width: 40px;
    height: 40px;
    background: linear-gradient(135deg, var(--rose-dark), var(--rose-gold));
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 0.5px;
    color: var(--dark);
    flex-shrink: 0;
  }

  .cert-name {
    font-size: 12px;
    font-weight: 500;
    color: var(--off-white);
    margin-bottom: 4px;
  }

  .cert-org {
    font-size: 10px;
    font-weight: 400;
    letter-spacing: 1px;
    color: var(--rose-gold);
    text-transform: uppercase;
  }

  /* ── EXPERTISE ─────────────────────────────────────────────────── */
  .expertise-section {
    background: var(--dark-mid);
    max-width: 100%;
    padding: 100px 0;
  }

  .expertise-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 60px;
  }

  .expertise-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: rgba(201,168,124,0.1);
  }

  .expertise-item {
    background: var(--dark-mid);
    padding: 48px 36px;
    position: relative;
    overflow: hidden;
    transition: all 0.3s ease;
  }

  .expertise-item::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: var(--rose-gold);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.4s ease;
  }

  .expertise-item:hover { background: var(--dark-card); }
  .expertise-item:hover::after { transform: scaleX(1); }

  .expertise-icon {
    font-size: 28px;
    margin-bottom: 20px;
  }

  .expertise-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: 22px;
    font-weight: 400;
    color: var(--white);
    margin-bottom: 12px;
  }

  .expertise-desc {
    font-size: 12px;
    font-weight: 300;
    line-height: 1.8;
    color: var(--mid);
  }

  /* ── SKILLS ────────────────────────────────────────────────────── */
  .skills-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .skill-tag {
    padding: 8px 18px;
    border: 1px solid rgba(201,168,124,0.2);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--light);
    transition: all 0.3s ease;
    cursor: default;
  }

  .skill-tag:hover {
    border-color: var(--rose-gold);
    color: var(--rose-gold);
    background: rgba(201,168,124,0.06);
  }

  /* ── CONTACT ───────────────────────────────────────────────────── */
  .contact-section {
    background: var(--dark-sidebar);
    max-width: 100%;
    padding: 100px 0;
    position: relative;
    overflow: hidden;
  }

  .contact-section::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--rose-gold), transparent);
  }

  .contact-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 60px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: start;
  }

  .contact-info {
    display: flex;
    flex-direction: column;
    gap: 24px;
    margin-top: 40px;
  }

  .contact-item {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 20px;
    background: rgba(0,0,0,0.2);
    border: 1px solid rgba(201,168,124,0.1);
    text-decoration: none;
    transition: all 0.3s ease;
  }

  .contact-item:hover {
    border-color: rgba(201,168,124,0.4);
    background: rgba(201,168,124,0.05);
  }

  .contact-icon {
    width: 40px;
    height: 40px;
    background: rgba(201,168,124,0.1);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 16px;
    flex-shrink: 0;
  }

  .contact-detail {
    flex: 1;
  }

  .contact-label {
    font-size: 9px;
    font-weight: 600;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--rose-gold);
    margin-bottom: 4px;
  }

  .contact-value {
    font-size: 13px;
    font-weight: 300;
    color: var(--off-white);
  }

  /* Contact form */
  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 16px;
    margin-top: 40px;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .form-group label {
    font-size: 9px;
    font-weight: 600;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--rose-gold);
  }

  .form-group input,
  .form-group textarea {
    background: rgba(0,0,0,0.3);
    border: 1px solid rgba(201,168,124,0.15);
    padding: 14px 18px;
    font-family: 'Montserrat', sans-serif;
    font-size: 13px;
    font-weight: 300;
    color: var(--off-white);
    outline: none;
    transition: border-color 0.3s ease;
    resize: none;
  }

  .form-group input:focus,
  .form-group textarea:focus {
    border-color: rgba(201,168,124,0.5);
  }

  .form-group input::placeholder,
  .form-group textarea::placeholder {
    color: rgba(187,175,168,0.4);
  }

  .form-submit {
    padding: 16px 40px;
    background: var(--rose-gold);
    color: var(--dark);
    font-family: 'Montserrat', sans-serif;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    border: none;
    cursor: pointer;
    transition: all 0.3s ease;
    align-self: flex-start;
  }

  .form-submit:hover {
    background: var(--rose-mid);
    transform: translateY(-2px);
  }

  /* ── FOOTER ────────────────────────────────────────────────────── */
  footer {
    background: var(--dark);
    padding: 40px 60px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-top: 1px solid rgba(201,168,124,0.1);
  }

  .footer-name {
    font-family: 'Cormorant Garamond', serif;
    font-size: 18px;
    font-weight: 300;
    color: var(--light);
  }

  .footer-name span { color: var(--rose-gold); }

  .footer-copy {
    font-size: 10px;
    font-weight: 400;
    letter-spacing: 1px;
    color: rgba(187,175,168,0.4);
  }

  /* ── DIVIDER LINE ──────────────────────────────────────────────── */
  .full-divider {
    width: 100%;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(201,168,124,0.3), transparent);
    margin: 0;
  }

  /* ── SCROLL REVEAL ─────────────────────────────────────────────── */
  .reveal {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.7s ease, transform 0.7s ease;
  }

  .reveal.visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* ── RESPONSIVE ────────────────────────────────────────────────── */
  @media (max-width: 900px) {
    nav { padding: 20px 30px; }
    .nav-links { display: none; }
    .hero-content { grid-template-columns: 1fr; gap: 60px; padding: 100px 30px 60px; }
    section { padding: 70px 30px; }
    .about-grid { grid-template-columns: 1fr; gap: 48px; }
    .expertise-grid { grid-template-columns: 1fr; }
    .contact-inner { grid-template-columns: 1fr; gap: 40px; }
    footer { flex-direction: column; gap: 16px; text-align: center; padding: 30px; }
    .expertise-inner { padding: 0 30px; }
    .contact-inner { padding: 0 30px; }
  }
</style>
</head>
